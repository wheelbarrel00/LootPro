package-as: LootPro

enable-nolib-creation: no

changelog-title: LootPro
manual-changelog:
  filename: .release_changelog.md
  markup-type: markdown

ignore:
  - .pkgmeta
  - .github
  - .gitignore
  - .vscode
  - .git
  - README.md
  - CHANGELOG.md
  - .claude
  - screenshots
  - LICENSE
  - .release_changelog.md